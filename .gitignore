# 环境变量与密钥：真实 .env 永远不进 Git，只保留 .env.example 模板。
.env
.env.*
!.env.example

# Python 构建、缓存和二进制产物。
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# IDE/编辑器本地状态。
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# 操作系统临时文件。
.DS_Store
Thumbs.db

# 本地临时文件、覆盖率和冲突补丁残留。
/.coverage
/.coverage.*
/_t.py
/_ti.py
/*.err
*.bak
*.bak-*
*.orig
*.rej

# MASE 运行产物。这里锚定到项目根，避免误排除 `mase_tools/memory/` 源码包。
/memory/
/data/
results/
event-bus-latest.json
*.log
# 本地 Windows 启动器(屏蔽被父进程注入的坏 PYTHONHOME),只在本机用,不入库。
/run_mase.ps1

# 前端 Node 依赖 / 构建产物,绝不入库(任意层级)。
node_modules/
frontend/dist/
frontend/dev-server.log

# === 2026-04-19 公开发布前新增 ===
# MASE 运行产物不能提交，否则会把本地记忆库和 benchmark 结果带进仓库。
data/mase_memory.db
data/mase_memory.db-wal
data/mase_memory.db-shm
memory_runs/
# 只忽略仓库根目录的每日 markdown 审计日志，不匹配 `mase_tools/memory/` 源码包。
/memory/
results/*.json
results/external/
scripts/_*.log
scripts/_*.json
*.log

# 大型 benchmark 数据集需要单独下载，源码仓库只保留说明和 .gitkeep。
data/longmemeval-official/
data/longmemeval_official/
data/longmemeval/
data/lveval/
data/bamboo/
data/nolima/
data/**/*.json
data/**/*.jsonl
!data/.gitkeep


# === 仓库瘦身(2026-04-19) ===
# 第三方 benchmark 代码/数据集单独获取；保留 README 和必要适配入口。
/benchmarks/external-benchmarks/*
!/benchmarks/external-benchmarks/README.md
!/benchmarks/external-benchmarks/NoLiMa/
/benchmarks/external-benchmarks/NoLiMa/*
!/benchmarks/external-benchmarks/NoLiMa/run_mase_official.py
# 发布口径的 MASE chunked runner 必须可复现,纳入追踪(2026-07-07 取证后补)。
!/benchmarks/external-benchmarks/NoLiMa/run_mase_chunked.py

/run_artifacts/
/proposals/
/config.lme_cloud_swap.json
scripts/_*.py
scripts/_*.txt
scripts/_*.err
scripts/_*.ps1
scripts/_external_logs/


# --- 分发/营销草稿：个人内容，不入公开技术仓库(2026-07-12) ---
/被看见_分发计划_30天.md
/技术帖_白盒可审计记忆_草稿.md
/小红书版_差点发了个假数据.md

# --- 密钥/私人笔记：密钥泄漏审计后加固 ---
/docs/notes/
*.secret
*.secrets
secrets.*
*api_key*
*api-key*
.env.local
.env.*.local
.worktrees/

# 前端依赖、构建产物和缓存。
node_modules/
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.cache/
frontend/.vite/
frontend/*.tsbuildinfo
