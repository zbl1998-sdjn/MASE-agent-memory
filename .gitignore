# 环境变量与密钥：真实 .env 永远不进 Git，只保留 .env.example 模板。
.env
.env.*
!.env.example

# Python 构建、缓存和二进制产物。
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# IDE/编辑器本地状态。
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# 操作系统临时文件。
.DS_Store
Thumbs.db

# 本地临时文件、覆盖率和冲突补丁残留。
/.coverage
/.coverage.*
/_t.py
/_ti.py
/*.err
*.bak
*.bak-*
*.orig
*.rej

# MASE 运行产物。这里锚定到项目根，避免误排除 `mase_tools/memory/` 源码包。
/memory/
/data/
results/
event-bus-latest.json
*.log

# === 2026-04-19 公开发布前新增 ===
# MASE 运行产物不能提交，否则会把本地记忆库和 benchmark 结果带进仓库。
data/mase_memory.db
data/mase_memory.db-wal
data/mase_memory.db-shm
memory_runs/
# 只忽略仓库根目录的每日 markdown 审计日志，不匹配 `mase_tools/memory/` 源码包。
/memory/
results/*.json
results/external/
scripts/_*.log
scripts/_*.json
*.log

# 大型 benchmark 数据集需要单独下载，源码仓库只保留说明和 .gitkeep。
data/longmemeval-official/
data/longmemeval_official/
data/longmemeval/
data/lveval/
data/bamboo/
data/nolima/
data/**/*.json
data/**/*.jsonl
!data/.gitkeep


# === 仓库瘦身(2026-04-19) ===
# 第三方 benchmark 代码/数据集单独获取；保留 README 和必要适配入口。
/benchmarks/external-benchmarks/*
!/benchmarks/external-benchmarks/README.md
!/benchmarks/external-benchmarks/NoLiMa/
/benchmarks/external-benchmarks/NoLiMa/*
!/benchmarks/external-benchmarks/NoLiMa/run_mase_official.py

/run_artifacts/
/proposals/
/config.lme_cloud_swap.json
scripts/_*.py
scripts/_*.txt
scripts/_*.err
scripts/_*.ps1
scripts/_external_logs/


# --- 密钥/私人笔记：密钥泄漏审计后加固 ---
/docs/notes/
*.secret
*.secrets
secrets.*
*api_key*
*api-key*
.env.local
.env.*.local
.worktrees/

# 前端依赖、构建产物和缓存。
node_modules/
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.cache/
frontend/.vite/
frontend/*.tsbuildinfo
