{
  "version": 1,
  "description": "Fixed official-generalization smoke suite for LongMemEval, BAMBOO, and NoLiMa.",
  "suites": [
    {
      "name": "longmemeval-official-smoke",
      "kind": "longmemeval",
      "official_data": [
        "data\\longmemeval-official\\longmemeval_s_cleaned.json"
      ],
      "commands": [
        "python .\\scripts\\benchmarks\\run_standard_benchmark.py --benchmark longmemeval_s --path data\\longmemeval-official\\longmemeval_s_cleaned.json --sample-limit 8"
      ],
      "scoring": "Built into run_standard_benchmark.py summary JSON.",
      "notes": "Use the official cleaned LongMemEval local file as the fixed smoke subset source."
    },
    {
      "name": "bamboo-official-smoke",
      "kind": "bamboo",
      "official_data": [
        "external-benchmarks\\BAMBOO\\datasets\\meetingqa_4k.jsonl",
        "external-benchmarks\\BAMBOO\\datasets\\paperqa_4k.jsonl",
        "external-benchmarks\\BAMBOO\\datasets\\meetingpred_4k.jsonl",
        "external-benchmarks\\BAMBOO\\datasets\\showssort_4k.jsonl"
      ],
      "commands": [
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\meetingqa_4k.jsonl --limit 3 --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\meetingqa_smoke",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task meetingqa --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\meetingqa_smoke\\meetingqa.predictions.jsonl",
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\paperqa_4k.jsonl --limit 3 --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\paperqa_smoke",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task paperqa --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\paperqa_smoke\\paperqa.predictions.jsonl",
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\meetingpred_4k.jsonl --limit 3 --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\meetingpred_smoke",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task meetingpred --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\meetingpred_smoke\\meetingpred.predictions.jsonl",
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\showssort_4k.jsonl --limit 3 --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\showssort_smoke",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task showssort --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\regression\\showssort_smoke\\showssort.predictions.jsonl"
      ],
      "scoring": "Official BAMBOO evaluate.py via evaluate_official_compat.py.",
      "notes": "This fixed subset mirrors the previously validated 3-sample official smoke runs."
    },
    {
      "name": "nolima-official-smoke",
      "kind": "nolima",
      "official_data": [
        "external-benchmarks\\NoLiMa\\data\\needlesets\\needle_set_ONLYDirect.json",
        "external-benchmarks\\NoLiMa\\data\\needlesets\\needle_set.json",
        "external-benchmarks\\NoLiMa\\data\\haystack\\rand_shuffle\\rand_book_1.txt"
      ],
      "commands": [
        "python .\\scripts\\benchmarks\\run_nolima_mase_smoke.py"
      ],
      "scoring": "Official NoLiMa harness summary written to {runs_dir}\\results\\nolima\\mase-nolima-summary.json.",
      "notes": "Tracks both the direct 1K smoke slice and the one-hop 2K extended slice."
    },
    {
      "name": "nolima-official-max",
      "kind": "nolima",
      "official_data": [
        "external-benchmarks\\NoLiMa\\data\\needlesets\\needle_set.json",
        "external-benchmarks\\NoLiMa\\data\\haystack\\rand_shuffle"
      ],
      "commands": [
        "python .\\external-benchmarks\\NoLiMa\\run_mase_official.py --needle-set-path external-benchmarks\\NoLiMa\\data\\needlesets\\needle_set.json --haystack-dir external-benchmarks\\NoLiMa\\data\\haystack\\rand_shuffle --context-length 2000 --document-depth-percent-min 50 --document-depth-percent-max 50 --document-depth-percent-intervals 1 --executor-role reasoning --run-dir {runs_dir}\\external-benchmarks\\NoLiMa\\outputs\\official-max-needle_set_2000_depth50"
      ],
      "scoring": "Official NoLiMa harness summary in {runs_dir}\\external-benchmarks\\NoLiMa\\outputs\\official-max-needle_set_2000_depth50\\nolima.summary.json.",
      "notes": "Runs the full needle_set.json against all shuffled haystacks at the fixed 50% depth slice."
    },
    {
      "name": "bamboo-official-max",
      "kind": "bamboo",
      "official_data": [
        "external-benchmarks\\BAMBOO\\datasets\\meetingqa_16k.jsonl",
        "external-benchmarks\\BAMBOO\\datasets\\paperqa_4k.jsonl",
        "external-benchmarks\\BAMBOO\\datasets\\meetingpred_16k.jsonl",
        "external-benchmarks\\BAMBOO\\datasets\\showssort_16k.jsonl"
      ],
      "commands": [
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\meetingqa_16k.jsonl --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-meetingqa-16k",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task meetingqa --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-meetingqa-16k\\meetingqa.predictions.jsonl",
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\paperqa_4k.jsonl --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-paperqa-4k",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task paperqa --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-paperqa-4k\\paperqa.predictions.jsonl",
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\meetingpred_16k.jsonl --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-meetingpred-16k",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task meetingpred --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-meetingpred-16k\\meetingpred.predictions.jsonl",
        "python .\\external-benchmarks\\BAMBOO\\run_mase_official.py --dataset external-benchmarks\\BAMBOO\\datasets\\showssort_16k.jsonl --run-dir {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-showssort-16k",
        "python .\\external-benchmarks\\BAMBOO\\evaluate_official_compat.py --task showssort --input_path {runs_dir}\\external-benchmarks\\BAMBOO\\outputs\\official-max-showssort-16k\\showssort.predictions.jsonl"
      ],
      "scoring": "Official BAMBOO evaluate.py via evaluate_official_compat.py.",
      "notes": "Runs the full 16k slices where available; paperqa_16k.jsonl is malformed in this checkout, so paperqa uses the full 4k slice."
    }
  ]
}
