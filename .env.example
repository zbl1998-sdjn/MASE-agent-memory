# MASE 环境变量模板：复制为 .env 后再填真实值。
# 真实 .env 已被 .gitignore 忽略，绝不要提交。

# --- 模型供应商 API key ---
# DeepSeek：Anthropic 兼容端点。
DEEPSEEK_API_KEY=sk-__replace_me__
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# MiniMax：Anthropic 兼容端点。
MINIMAX_API_KEY=sk-__replace_me__
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# 阿里 Qwen3.5 Plus：DashScope 的 Anthropic 兼容端点。
QWEN35_PLUS_API_KEY=sk-__replace_me__
QWEN35_PLUS_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# Moonshot Kimi K2.5。
KIMI_K25_API_KEY=sk-__replace_me__
KIMI_K25_BASE_URL=https://api.kimi.com/coding/

# 智谱 GLM 5.1：Anthropic 兼容端点。
GLM51_API_KEY=__replace_me__
GLM51_BASE_URL=https://open.bigmodel.cn/api/anthropic

# --- MASE 运行时开关 ---
# 1 表示 executor 可根据任务自主选择模型；0 表示关闭自主模型选择。
MASE_ENABLE_MODEL_AUTONOMY=1
